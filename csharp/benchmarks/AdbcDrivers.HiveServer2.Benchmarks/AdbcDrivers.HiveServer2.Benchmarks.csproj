<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <!-- BenchmarkDotNet generates a bootstrap project that does not satisfy
         the repo-wide warnings-as-errors policy; relax it here only. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
  </ItemGroup>

  <!-- Referenced for the real Apache.Arrow ArrowBuffer.BitmapBuilder baseline
       in the boolean-packing benchmark (Apache.Arrow flows transitively). -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\AdbcDrivers.HiveServer2\AdbcDrivers.HiveServer2.csproj" />
  </ItemGroup>

</Project>
